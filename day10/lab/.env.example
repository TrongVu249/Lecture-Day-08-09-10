# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# ChromaDB (khuyến nghị tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding (SentenceTransformers — offline)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Freshness SLA (giờ) — dùng trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24

# Policy versioning — ngày cutoff tối thiểu cho HR leave policy (ISO YYYY-MM-DD)
# Distinction criterion (d): không hard-code trong code, đọc từ env để inject khác giá trị
# chứng minh quyết định clean thay đổi theo cấu hình.
HR_LEAVE_MIN_EFFECTIVE_DATE=2026-01-01

# Tuỳ chọn: OpenAI chỉ cần nếu nhóm mở rộng eval bằng LLM-judge
# OPENAI_API_KEY= 
